  "flows": [
    { "from": "endpoints", "to": "switch", "label": "all traffic", "classification": "cleartext DNS+TLS", "variant": "default", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [206, 388] },
    { "from": "switch", "to": "sensor", "label": "mirrored copy", "classification": "out-of-band", "variant": "emphasis", "fromSide": "right", "toSide": "left" },
