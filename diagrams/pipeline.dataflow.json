    { "id": "device", "type": "database", "label": "Device Registry", "sublabel": "MAC ↔ IP lease", "stage": 3, "row": 1, "tag": "identity" },
    { "id": "catalog", "type": "database", "label": "Software Catalog", "sublabel": "domain → app patterns", "stage": 3, "row": 3, "tag": "L2 rules" },
    { "id": "risk", "type": "security", "label": "Risk Scoring", "sublabel": "policy engine", "stage": 4, "row": 0, "tag": "green/amber/red" },
    { "id": "store", "type": "database", "label": "Event Store", "sublabel": "metadata only", "stage": 4, "row": 2, "tag": "self-hosted" },
