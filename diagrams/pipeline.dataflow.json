    { "from": "catalog", "to": "store", "label": "software event", "classification": "append", "variant": "default", "fromSide": "right", "toSide": "left", "labelAt": [940, 452] },
    { "from": "risk", "to": "store", "label": "scored event", "classification": "policy", "variant": "security", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [1058, 268] },
    { "from": "store", "to": "dashboard", "label": "query", "classification": "read", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [1058, 496] }
  ],
  "cards": [
    {
      "dot": "emerald",
      "title": "Đường đi chính (hot path)",
      "items": [
        "Tap → Capture → nDPI → Match → Dashboard, chạy trái sang phải",
        "Sensor chỉ nhận BẢN SAO traffic qua port-mirror, không nằm inline nên không làm gián đoạn mạng",
        "nDPI đọc TLS ClientHello để lấy SNI và DNS query — không giải mã payload"
      ]
    },
    {
      "dot": "rose",
      "title": "Vì sao không cần agent",
      "items": [
        "Mọi tín hiệu lấy từ mạng (DNS + SNI), không cài gì lên máy nhân viên → hợp BYOD",
        "Chỉ lưu metadata: domain/SNI, phần mềm match, MAC/IP, thời điểm",
        "Risk scoring gắn nhãn green/amber/red theo policy nội bộ, không kết luận pháp lý"
      ]
    },
    {
      "dot": "orange",
      "title": "Blind spot (giới hạn cố hữu)",
      "items": [
        "VPN / mobile hotspot: traffic nằm trong tunnel → không thấy SNI bên trong",
        "DoH / DoT: DNS bị mã hoá → mất tín hiệu hostname",
        "ECH (Encrypted ClientHello): SNI bị mã hoá → nDPI không đọc được",
        "Crack/KMS chạy local không phát traffic ra mạng → không thấy"
      ]
    }
  ]
}
